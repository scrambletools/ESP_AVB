CompileFlags:
  CompilationDatabase: build.clang/
  Remove:
    - -fno-shrink-wrap
    - -fstrict-volatile-bitfields
    - -fno-tree-switch-conversion
    - -fzero-init-padding-bits=all
    - -fno-malloc-dce
    - -mtune=esp-base
    - -march=*

InlayHints:
  Enabled: false

Diagnostics:
  UnusedIncludes: None
